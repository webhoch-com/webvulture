NODE_ENV=development
PORT=3001

# PostgreSQL
DATABASE_URL=postgresql://webhoch:webhoch_secret@localhost:5432/webhoch_vorschau

# JWT Secret (min 32 Zeichen)
JWT_SECRET=change-me-to-a-random-secret-string-min-32-chars

# Encryption Key fuer API Keys (64 hex chars = 32 bytes)
ENCRYPTION_KEY=change-me-to-64-hex-characters-0123456789abcdef0123456789abcdef

# Teaser Config
TEASER_DOMAIN=webseiten-werkstatt.at
TEASER_FILES_PATH=/var/www/teasers
