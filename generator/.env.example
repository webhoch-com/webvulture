PORT=4000
HOST=0.0.0.0

ANTHROPIC_API_KEY=sk-ant-...
GENERATION_MODEL=claude-sonnet-4-6

# Must match Laravel GENERATOR_SECRET
WV_SECRET=test

# Where Astro projects are scaffolded
PROJECTS_DIR=/tmp/wv-projects

# Where built dist/ folders are copied
ARTIFACTS_DIR=/tmp/wv-artifacts

# Base URL for preview links sent back to Laravel
PREVIEW_BASE_URL=http://localhost:4000
